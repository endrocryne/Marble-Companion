<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MarbleCompanion.Mobile.ViewModels"
    x:Class="MarbleCompanion.Mobile.Views.FriendsPage"
    x:DataType="vm:FriendsViewModel"
    Title="Friends"
    BackgroundColor="{StaticResource BackgroundLight}">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">

        <!-- Search -->
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <SearchBar Placeholder="Find friends..." Text="{Binding SearchQuery}" />
            <Button Grid.Column="1" Text="🔍" WidthRequest="48" HeightRequest="48" Padding="0" CornerRadius="24" Command="{Binding SearchCommand}" />
        </Grid>

        <RefreshView Grid.Row="1" Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy}">
            <ScrollView>
                <VerticalStackLayout Spacing="12">

                    <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}" IsVisible="{Binding ErrorMessage, Converter={x:StaticResource IsNotNullConverter}}" />

                    <!-- Search Results -->
                    <VerticalStackLayout IsVisible="{Binding IsSearching}" Spacing="8">
                        <ActivityIndicator IsRunning="True" HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <CollectionView ItemsSource="{Binding SearchResults}" IsVisible="{Binding SearchResults.Count}">
                        <CollectionView.Header>
                            <Label Text="Search Results" Style="{StaticResource SubtitleLabel}" Margin="0,0,0,8" />
                        </CollectionView.Header>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:Object">
                                <Frame Margin="0,0,0,6" Padding="12">
                                    <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="12">
                                        <Frame WidthRequest="40" HeightRequest="40" CornerRadius="20" BackgroundColor="{StaticResource Accent}" Padding="0" HasShadow="False">
                                            <Label Text="{Binding AvatarIndex}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontFamily="Georgia" />
                                        </Frame>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding DisplayName}" FontAttributes="Bold" FontFamily="Georgia" />
                                            <Label Text="{Binding TotalLP, StringFormat='{0} LP'}" FontSize="12" TextColor="{StaticResource TextSecondary}" FontFamily="Georgia" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="2" Text="Add" Style="{StaticResource SecondaryButton}" Padding="12,6" FontSize="13" HeightRequest="36" VerticalOptions="Center"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FriendsViewModel}}, Path=SendRequestCommand}" CommandParameter="{Binding Id}" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Pending Requests -->
                    <CollectionView ItemsSource="{Binding PendingRequests}" IsVisible="{Binding HasPendingRequests}">
                        <CollectionView.Header>
                            <Label Text="Pending Requests" Style="{StaticResource SubtitleLabel}" Margin="0,8,0,8" />
                        </CollectionView.Header>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:Object">
                                <Frame Margin="0,0,0,6" Padding="12">
                                    <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="12">
                                        <Frame WidthRequest="40" HeightRequest="40" CornerRadius="20" BackgroundColor="{StaticResource Secondary}" Padding="0" HasShadow="False">
                                            <Label Text="{Binding FromAvatarIndex}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontFamily="Georgia" />
                                        </Frame>
                                        <Label Grid.Column="1" Text="{Binding FromDisplayName}" FontAttributes="Bold" VerticalOptions="Center" FontFamily="Georgia" />
                                        <Button Grid.Column="2" Text="Accept" BackgroundColor="{StaticResource Success}" Padding="12,6" FontSize="13" HeightRequest="36" VerticalOptions="Center"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FriendsViewModel}}, Path=AcceptRequestCommand}" CommandParameter="{Binding Id}" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Friends List -->
                    <CollectionView ItemsSource="{Binding Friends}">
                        <CollectionView.Header>
                            <Label Text="Your Friends" Style="{StaticResource SubtitleLabel}" Margin="0,8,0,8" />
                        </CollectionView.Header>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:Object">
                                <Frame Margin="0,0,0,6" Padding="12">
                                    <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="12">
                                        <Frame WidthRequest="44" HeightRequest="44" CornerRadius="22" BackgroundColor="{StaticResource Accent}" Padding="0" HasShadow="False">
                                            <Label Text="{Binding AvatarIndex}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="18" FontFamily="Georgia" />
                                        </Frame>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding DisplayName}" FontAttributes="Bold" FontFamily="Georgia" />
                                            <Label Text="{Binding CurrentStreak, StringFormat='🔥 {0} day streak'}" FontSize="12" TextColor="{StaticResource TextSecondary}" FontFamily="Georgia" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="{Binding TotalLP, StringFormat='{0} LP'}" TextColor="{StaticResource Primary}" FontAttributes="Bold" VerticalOptions="Center" FontFamily="Georgia" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

    </Grid>

</ContentPage>
