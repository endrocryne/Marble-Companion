<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MarbleCompanion.Mobile.ViewModels"
    xmlns:controls="clr-namespace:MarbleCompanion.Mobile.Controls"
    x:Class="MarbleCompanion.Mobile.Views.ContentLibraryPage"
    x:DataType="vm:ContentLibraryViewModel"
    Title="Learn"
    BackgroundColor="{StaticResource BackgroundLight}">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">
        <SearchBar Placeholder="Search articles..." Text="{Binding SearchQuery}" />
        <RefreshView Grid.Row="1" Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Articles}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="32" Spacing="8">
                        <Label Text="📚" FontSize="48" HorizontalTextAlignment="Center" />
                        <Label Text="No articles found" Style="{StaticResource SubtitleLabel}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:Object">
                        <Frame Margin="0,0,0,8" Padding="16">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ContentLibraryViewModel}}, Path=NavigateToDetailCommand}" CommandParameter="{Binding Id}" />
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" FontFamily="Georgia" />
                                <Label Text="{Binding Summary}" FontSize="13" TextColor="{StaticResource TextSecondary}" FontFamily="Georgia" MaxLines="2" LineBreakMode="TailTruncation" />
                                <HorizontalStackLayout Spacing="12">
                                    <Frame CornerRadius="10" Padding="8,2" HasShadow="False" BackgroundColor="{StaticResource Accent}"><Label Text="{Binding Difficulty}" FontSize="11" FontFamily="Georgia" /></Frame>
                                    <Label Text="{Binding Category}" FontSize="12" TextColor="{StaticResource Primary}" VerticalOptions="Center" FontFamily="Georgia" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
